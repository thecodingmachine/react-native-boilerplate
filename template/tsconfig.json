{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["react-native", "jest", "node"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "noUnusedLocals": true,
    "allowJs": true // For eslint and prettier configs
  },
  "include": [
    "src/__tests__/**/*",
    "./src/**/*",
    "index.d.ts",
    "*.mjs",
    ".*.mjs",
    "*.js",
    ".*.js",
    "*.ts",
    ".prettierrc.mjs",
    "eslint/**/*.mjs"
  ],
  "exclude": ["**/node_modules", "_", "android", "ios", "**/Pods"]
}
